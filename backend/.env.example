# ------------------------------------------------------------------------------
# API Keys (Required for ML and GenAI)
# ------------------------------------------------------------------------------
GEMINI_API_KEY="your-gemini-api-key-here"
PINECONE_API_KEY="your-pinecone-api-key-here"
PINECONE_INDEX_NAME="nexus-ai-rag"

# ------------------------------------------------------------------------------
# Database Connection (PostgreSQL)
# ------------------------------------------------------------------------------
POSTGRES_USER="nexus_user"
POSTGRES_PASSWORD="nexus_password"
POSTGRES_DB="nexus_db"
# Use "postgres" when running in docker-compose, "localhost" otherwise
POSTGRES_SERVER="localhost"
POSTGRES_PORT="5432"

# ------------------------------------------------------------------------------
# Redis Cache (Rate Limiting & Memory)
# ------------------------------------------------------------------------------
# Use "redis://redis:6379/0" when inside Docker
REDIS_URL="redis://localhost:6379/0"

# ------------------------------------------------------------------------------
# MinIO / S3 Storage (For Image / Document Assets)
# ------------------------------------------------------------------------------
MINIO_ROOT_USER="admin"
MINIO_ROOT_PASSWORD="password"
MINIO_SERVER="localhost:9000"

# ------------------------------------------------------------------------------
# Security & Authentication
# ------------------------------------------------------------------------------
# Generate a secret key with: openssl rand -hex 32
JWT_SECRET_KEY="your-super-secret-key-here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ------------------------------------------------------------------------------
# MLflow Tracking
# ------------------------------------------------------------------------------
# Use "http://mlflow:5000" internally inside Docker network
# For local testing, use "sqlite:///mlruns.db"
MLFLOW_TRACKING_URI="sqlite:///mlruns.db"
